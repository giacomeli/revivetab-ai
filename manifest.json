{
  "manifest_version": 3,
  "name": "Bookmark Dial",
  "version": "3.0.0",
  "description": "Speed dial dashboard for your bookmarks.",
  "permissions": [
    "bookmarks",
    "favicon",
    "storage"
  ],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "128": "icons/icon128.png"
  }
}
